# Database
MONGODB_URI=mongodb://localhost:27017/telesandhai

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development

# Security
# Comma separated list of allowed origins. Use * for wide open (insecure).
ALLOWED_ORIGINS=http://localhost:5173,http://yourproductiondomain.com

# Razorpay (Optional - for real payment integrations)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
