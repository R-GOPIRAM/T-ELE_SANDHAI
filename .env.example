# Frontend (Vite)
# If unset, the app uses '/api' in production (recommended: same-origin via Vercel rewrites)
# and 'http://localhost:5000/api' in dev.
# In production, avoid setting this to an absolute Render URL, or cookie auth may break due to
# third-party cookie restrictions.
VITE_API_URL=http://localhost:5000/api

# Socket.IO base URL (no /api suffix). If unset, uses '/' in production and 'http://localhost:5000' in dev.
VITE_SOCKET_URL=http://localhost:5000

